{
  "name": "WealthTracker",
  "description": "Wealth Tracker Electron desktop shell.",
  "version": "4.0.0",
  "author": "nicejade",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "dev": "npm run build && npx electron .",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepare-icons": "node ./scripts/generate-icons.mjs",
    "prepare-server": "node ./scripts/prepare-server.mjs",
    "pack": "npm run prepare-icons && electron-builder --dir --config electron-builder.yml",
    "pack:verify": "npm run pack && node ./scripts/verify-release.mjs --mode=pack",
    "dist": "npm run prepare-icons && electron-builder --config electron-builder.yml",
    "dist:verify": "npm run dist && node ./scripts/verify-release.mjs --mode=dist",
    "dist:mac": "npm run prepare-icons && electron-builder --mac --config electron-builder.yml",
    "dist:mac:verify": "npm run dist:mac && node ./scripts/verify-release.mjs --mode=dist --platform=mac",
    "dist:win": "npm run prepare-icons && electron-builder --win --config electron-builder.yml",
    "dist:win:verify": "npm run dist:win && node ./scripts/verify-release.mjs --mode=dist --platform=win",
    "dist:linux": "npm run prepare-icons && electron-builder --linux --config electron-builder.yml",
    "dist:linux:verify": "npm run dist:linux && node ./scripts/verify-release.mjs --mode=dist --platform=linux"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  }
}
